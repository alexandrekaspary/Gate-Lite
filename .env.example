DJANGO_SECRET_KEY=troque-por-um-segredo-longo-e-aleatorio
KEY_ENCRYPTION_SECRET=troque-por-outro-segredo-longo-e-aleatorio
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=auth.exemplo.com
CSRF_TRUSTED_ORIGINS=https://auth.exemplo.com
OIDC_ISSUER=https://auth.exemplo.com
TRUST_PROXY_SSL_HEADER=1
DB_ENGINE=postgres
DB_NAME=gatelite
DB_USER=gatelite
DB_PASSWORD=troque-pela-senha-do-banco
DB_HOST=localhost
DB_PORT=5432
